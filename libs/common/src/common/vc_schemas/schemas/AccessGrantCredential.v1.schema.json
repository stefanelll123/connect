{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.gov/vc/AccessGrantCredential/v1",
  "title": "AccessGrantCredential",
  "description": "JWT claim set for an Access Grant Verifiable Credential (W3C VC DM v2.0 + JWT-VC). Grants a consumer Sentinel access to producer services. Maximum lifetime: 30 days for prod. credentialStatus is mandatory.",
  "type": "object",
  "required": ["iss", "sub", "aud", "nbf", "exp", "jti", "vc"],
  "additionalProperties": true,
  "properties": {
    "iss": {
      "type": "string",
      "pattern": "^did:",
      "maxLength": 512,
      "description": "Issuer DID (Producer authority or Discovery)."
    },
    "sub": {
      "type": "string",
      "pattern": "^did:",
      "maxLength": 512,
      "description": "Consumer Sentinel DID. Must equal vc.credentialSubject.id."
    },
    "aud": {
      "type": "string",
      "pattern": "^did:",
      "maxLength": 512,
      "description": "Producer Service DID. Exact match required. Must equal vc.credentialSubject.aud."
    },
    "nbf": {
      "type": "integer",
      "minimum": 0
    },
    "exp": {
      "type": "integer",
      "minimum": 0,
      "description": "Expiry timestamp. Must be > nbf. In prod, must be <= nbf + 2592000 (30 days)."
    },
    "jti": {
      "type": "string",
      "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "vc": {
      "type": "object",
      "required": ["type", "credentialSubject", "credentialStatus"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "array",
          "items": {"type": "string"},
          "contains": {"const": "AccessGrantCredential"}
        },
        "credentialSubject": {
          "$ref": "#/$defs/AccessGrantSubject"
        },
        "credentialStatus": {
          "$ref": "#/$defs/CredentialStatus"
        }
      }
    }
  },
  "$defs": {
    "AccessGrantSubject": {
      "type": "object",
      "required": ["id", "aud", "env", "scope"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:",
          "maxLength": 512,
          "description": "Consumer Sentinel DID."
        },
        "aud": {
          "type": "string",
          "pattern": "^did:",
          "maxLength": 512,
          "description": "Producer Service DID — exact match against JWT aud."
        },
        "env": {
          "type": "string",
          "enum": ["dev", "test", "prod"]
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": {"$ref": "#/$defs/ScopeEntry"},
          "description": "Access scope entries."
        },
        "max_requests_per_minute": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 10000,
          "description": "Rate-limit hint (non-binding)."
        }
      }
    },
    "ScopeEntry": {
      "type": "object",
      "required": ["service_id", "path_glob", "methods"],
      "additionalProperties": false,
      "properties": {
        "service_id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{1,128}$"
        },
        "path_glob": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Path glob. ** requires approval_reference."
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
          }
        },
        "attributes": {
          "type": ["array", "null"],
          "maxItems": 20,
          "items": {"type": "string"},
          "description": "ABAC attribute constraints (informational)."
        },
        "approval_reference": {
          "type": ["string", "null"],
          "maxLength": 128,
          "description": "Required when path_glob contains **."
        }
      },
      "if": {
        "properties": {
          "path_glob": {"pattern": "\\*\\*"}
        }
      },
      "then": {
        "required": ["approval_reference"],
        "properties": {
          "approval_reference": {"type": "string", "minLength": 1}
        }
      }
    },
    "CredentialStatus": {
      "type": "object",
      "required": ["id", "type", "statusListIndex", "statusListCredential", "statusPurpose"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 2048},
        "type": {"type": "string", "const": "BitstringStatusListEntry"},
        "statusListIndex": {"type": "string", "pattern": "^\\d+$"},
        "statusListCredential": {"type": "string", "minLength": 1, "maxLength": 2048},
        "statusPurpose": {"type": "string", "enum": ["revocation", "suspension"]}
      }
    }
  }
}
