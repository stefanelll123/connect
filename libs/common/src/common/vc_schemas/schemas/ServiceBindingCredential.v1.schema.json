{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.gov/vc/ServiceBindingCredential/v1",
  "title": "ServiceBindingCredential",
  "description": "JWT claim set for a Service Binding Verifiable Credential (W3C VC DM v2.0 + JWT-VC). Binds a Sentinel DID to a specific service in a specific environment. Maximum lifetime: 90 days for prod.",
  "type": "object",
  "required": ["iss", "sub", "nbf", "exp", "jti", "vc"],
  "additionalProperties": true,
  "properties": {
    "iss": {
      "type": "string",
      "pattern": "^did:",
      "maxLength": 512,
      "description": "Issuer DID (Service Owner authority)."
    },
    "sub": {
      "type": "string",
      "pattern": "^did:",
      "maxLength": 512,
      "description": "Subject DID (Sentinel). Must equal vc.credentialSubject.sentinel_did."
    },
    "nbf": {
      "type": "integer",
      "minimum": 0
    },
    "exp": {
      "type": "integer",
      "minimum": 0,
      "description": "Expiry timestamp. Must be > nbf. In prod, must be <= nbf + 7776000 (90 days)."
    },
    "jti": {
      "type": "string",
      "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "vc": {
      "type": "object",
      "required": ["type", "credentialSubject"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "array",
          "items": {"type": "string"},
          "contains": {"const": "ServiceBindingCredential"}
        },
        "credentialSubject": {
          "$ref": "#/$defs/ServiceBindingSubject"
        },
        "credentialStatus": {
          "oneOf": [
            {"$ref": "#/$defs/CredentialStatus"},
            {"type": "null"}
          ],
          "description": "Optional for non-prod environments."
        }
      }
    }
  },
  "$defs": {
    "ServiceBindingSubject": {
      "type": "object",
      "required": ["sentinel_did", "service_id", "env"],
      "additionalProperties": false,
      "properties": {
        "sentinel_did": {
          "type": "string",
          "pattern": "^did:",
          "maxLength": 512
        },
        "service_id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{1,128}$"
        },
        "env": {
          "type": "string",
          "enum": ["dev", "test", "prod"]
        },
        "valid_endpoint_patterns": {
          "type": ["array", "null"],
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 512
          },
          "description": "URL glob patterns for allowed endpoints."
        }
      }
    },
    "CredentialStatus": {
      "type": "object",
      "required": ["id", "type", "statusListIndex", "statusListCredential", "statusPurpose"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 2048},
        "type": {"type": "string", "const": "BitstringStatusListEntry"},
        "statusListIndex": {"type": "string", "pattern": "^\\d+$"},
        "statusListCredential": {"type": "string", "minLength": 1, "maxLength": 2048},
        "statusPurpose": {"type": "string", "enum": ["revocation", "suspension"]}
      }
    }
  }
}
