{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.gov/vc/SentinelIdentityCredential/v1",
  "title": "SentinelIdentityCredential",
  "description": "JWT claim set for a Sentinel Identity Verifiable Credential (W3C VC DM v2.0 + JWT-VC). Maximum lifetime: 365 days.",
  "type": "object",
  "required": ["iss", "sub", "nbf", "exp", "jti", "vc"],
  "additionalProperties": true,
  "properties": {
    "iss": {
      "type": "string",
      "pattern": "^did:",
      "maxLength": 512,
      "description": "Issuer DID (Discovery service)."
    },
    "sub": {
      "type": "string",
      "pattern": "^did:",
      "maxLength": 512,
      "description": "Subject DID (Sentinel). Must equal vc.credentialSubject.id."
    },
    "nbf": {
      "type": "integer",
      "minimum": 0,
      "description": "Not-before timestamp (Unix seconds)."
    },
    "exp": {
      "type": "integer",
      "minimum": 0,
      "description": "Expiry timestamp (Unix seconds). Must be > nbf and <= nbf + 31536000 (365 days)."
    },
    "jti": {
      "type": "string",
      "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
      "description": "JWT ID — must be unique per issuance."
    },
    "vc": {
      "type": "object",
      "required": ["type", "credentialSubject", "credentialStatus"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "array",
          "items": {"type": "string"},
          "contains": {"const": "SentinelIdentityCredential"},
          "description": "Must include 'VerifiableCredential' and 'SentinelIdentityCredential'."
        },
        "credentialSubject": {
          "$ref": "#/$defs/SentinelIdentitySubject"
        },
        "credentialStatus": {
          "$ref": "#/$defs/CredentialStatus"
        }
      }
    }
  },
  "$defs": {
    "SentinelIdentitySubject": {
      "type": "object",
      "required": ["id", "role", "service_id", "env"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:",
          "maxLength": 512,
          "description": "Sentinel DID."
        },
        "role": {
          "type": "string",
          "enum": ["PRODUCER", "CONSUMER"],
          "description": "Sentinel role."
        },
        "service_id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]{1,128}$",
          "description": "Service identifier (lowercase alphanumeric, hyphens, underscores)."
        },
        "env": {
          "type": "string",
          "enum": ["dev", "test", "prod"],
          "description": "Deployment environment."
        },
        "instance_count_hint": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 65535,
          "description": "Informational instance count (non-binding)."
        }
      }
    },
    "CredentialStatus": {
      "type": "object",
      "required": ["id", "type", "statusListIndex", "statusListCredential", "statusPurpose"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048,
          "description": "URL with index fragment."
        },
        "type": {
          "type": "string",
          "const": "BitstringStatusListEntry"
        },
        "statusListIndex": {
          "type": "string",
          "pattern": "^\\d+$",
          "description": "Bit position as a decimal string."
        },
        "statusListCredential": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048,
          "description": "URL of the status list VC."
        },
        "statusPurpose": {
          "type": "string",
          "enum": ["revocation", "suspension"]
        }
      }
    }
  }
}
