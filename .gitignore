# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
pip-wheel-metadata/
.installed.cfg

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# Test / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.local.example
*.key
*.pem
*.key.enc
.secrets.baseline

# ── Node / NPM ───────────────────────────────────────────────────────────────
**/node_modules/
.npm/
*.tgz

# ── Frontend build ───────────────────────────────────────────────────────────
frontend/*/dist/
frontend/*/.vite/

# ── Contracts ────────────────────────────────────────────────────────────────
# Build artifacts (re-generated by `npm run compile`)
contracts/artifacts/
contracts/cache/
contracts/typechain-types/
# Keep deployments/local.json (contract addresses) but not key files
contracts/deployments/*.key
contracts/deployments/*.secret

# ── Terraform ────────────────────────────────────────────────────────────────
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.backup
**/terraform.tfstate.d/
# Actual tfvars contain secrets — only commit the .example version
**/terraform.tfvars
!**/terraform.tfvars.example
# Crash / plan output files
crash.log
*.tfplan

# ── Load test results ────────────────────────────────────────────────────────
tests/load/results/

# ── Docker ───────────────────────────────────────────────────────────────────
.docker/

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temporary / stray files ───────────────────────────────────────────────────
*.tmp
*.bak
tmp/
temp/
# Windows artefacts that ended up in the repo root
nul
bash.exe.stackdump
=0.23.6

