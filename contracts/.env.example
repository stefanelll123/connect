# Sepolia testnet RPC endpoint (from Infura, Alchemy, etc.)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_KEY

# Testnet-only deployer private key — NEVER use a mainnet key here
DEPLOYER_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY_NEVER_MAINNET

# Optional: Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Set any non-empty value to enable gas reporting in tests
REPORT_GAS=
