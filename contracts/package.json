{
  "name": "sentinel-contracts",
  "version": "0.1.0",
  "description": "Smart contracts for the Sentinel decentralized identity trust layer",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy/deploy-local.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy/deploy-sepolia.ts --network sepolia",
    "export-abis": "ts-node scripts/export-abis.ts",
    "lint-sol": "solhint 'contracts/**/*.sol'",
    "typechain": "hardhat typechain"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0",
    "solhint": "^5.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@openzeppelin/hardhat-upgrades": "^3.9.1"
  }
}
