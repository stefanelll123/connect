# Copy this file to terraform.tfvars and fill in your values.
# Do NOT commit terraform.tfvars to source control (it contains secrets).

aws_region         = "us-east-1"
ssh_public_key_path = "~/.ssh/id_rsa.pub"
allowed_ssh_cidr   = "82.76.171.107/32"  # must include /32

git_repo_url       = "https://github.com/your-org/connect.git"
git_token          = ""                    # GitHub PAT for private repos; leave blank for public
github_repository  = "your-org/connect"

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
postgres_password         = "Test1234xConnect"
redis_password            = "Test1234xConnect"
secret_storage_master_key = "c4d9241122e50f5162d42fb144f25a5134739cc0b733535a769dfb7364b45f89"
sentinel_passphrase       = "fuiRsqWcoV4JfOk7H524IWJEUFNvow82"  # any string, e.g. output of: python -c "import secrets; print(secrets.token_urlsafe(24))"
discovery_admin_api_key   = "7TItpWzSr9H0i22BBbscTHv_GW9fRGDbfVEHVDovNiE"  # any string, e.g. output of: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Anvil deterministic account #0 — safe for ephemeral test chains only.
hardhat_private_key = "0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"

hub_instance_type  = "t3.large"
node_instance_type = "t3.medium"
