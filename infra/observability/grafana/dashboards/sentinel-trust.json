{
  "uid": "sentinel-trust",
  "title": "Sentinel — Revocation & Trust",
  "tags": ["sentinel", "trust", "revocation"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Status List Staleness (seconds)",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
      "targets": [{"refId": "A", "datasource": {"uid": "prometheus"}, "expr": "max(sentinel_status_list_age_seconds) by (issuer_did)"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": true},
      "fieldConfig": {"defaults": {"unit": "s", "min": 0, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 3600}, {"color": "red", "value": 7200}]}}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Trust Cache Hit Rate",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 4},
      "targets": [{"refId": "A", "datasource": {"uid": "prometheus"}, "expr": "sum(rate(sentinel_trust_cache_hits_total[5m])) / (sum(rate(sentinel_trust_cache_hits_total[5m])) + sum(rate(sentinel_trust_cache_misses_total[5m])))"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 0.8}, {"color": "green", "value": 0.95}]}}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Status List Refresh Failures",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 4},
      "targets": [{"refId": "A", "datasource": {"uid": "prometheus"}, "expr": "sum(increase(sentinel_status_list_refresh_failures_total[1h]))"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Revocation Check Latency (p95)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [{"refId": "A", "datasource": {"uid": "prometheus"}, "expr": "histogram_quantile(0.95, sum(rate(sentinel_revocation_check_duration_seconds_bucket[5m])) by (le, issuer_did))", "legendFormat": "{{issuer_did}}"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Status List Refresh Frequency",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [{"refId": "A", "datasource": {"uid": "prometheus"}, "expr": "sum(rate(sentinel_status_list_refreshed_total[5m])) by (issuer_did)", "legendFormat": "{{issuer_did}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    }
  ]
}
